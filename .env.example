# === CORE AI (Required for Extraction) ===
# Provide at least one of these. The UI sidebar lets you switch between them.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === ADVANCED PARSING (Required for LlamaParse) ===
# Get this from https://cloud.llamaindex.ai/
# If missing, the system automatically falls back to basic 'pypdf'
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# === INFRASTRUCTURE ===
# Default is a local SQLite file.
DATABASE_URL=sqlite:///./contract_orchestrator.db

# === SETTINGS ===
# Default options used by the app
PARSER_TYPE=pypdf        # Options: 'pypdf' or 'llamaparse'
LLM_PROVIDER=anthropic      # Options: 'openai' or 'anthropic'
RECURSION_LIMIT=5
DEBUG=True

# === EXTERNAL TOOLS (Optional/Mocked for Demo) ===
SIMPLYRETS_KEY=your_simplyrets_key
SIMPLYRETS_SECRET=your_simplyrets_secret
FUB_API_KEY=your_followupboss_api_key
